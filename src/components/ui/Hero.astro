---
interface Props {
  title: string;
  subtitle?: string;
  class?: string;
}

const { title, subtitle, class: className = '' } = Astro.props;
---

<section class:list={['relative py-20 sm:py-28 lg:py-36', className]}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold text-primary-dark leading-tight">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-4 sm:mt-6 text-lg sm:text-xl text-text-light max-w-2xl mx-auto">
        {subtitle}
      </p>
    )}
    <div class="mt-8 sm:mt-10 flex flex-wrap justify-center gap-4">
      <slot />
    </div>
  </div>
</section>
