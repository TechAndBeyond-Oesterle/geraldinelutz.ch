---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  external?: boolean;
  class?: string;
}

const { href, variant = 'primary', size = 'md', external = false, class: className = '' } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-semibold rounded-full transition-all duration-200';

const variants = {
  primary: 'bg-accent hover:bg-accent-dark text-primary-dark font-bold shadow-sm hover:shadow-md',
  secondary: 'bg-primary hover:bg-primary-dark text-white shadow-sm hover:shadow-md',
  outline: 'border-2 border-primary text-primary hover:bg-primary hover:text-white',
};

const sizes = {
  sm: 'px-5 py-2 text-sm',
  md: 'px-6 py-2.5 text-sm',
  lg: 'px-8 py-3.5 text-base',
};

const linkProps = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a
  href={href}
  class:list={[baseClasses, variants[variant], sizes[size], className]}
  {...linkProps}
>
  <slot />
</a>
