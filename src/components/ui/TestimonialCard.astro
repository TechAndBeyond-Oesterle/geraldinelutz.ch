---
interface Props {
  quote: string;
  author: string;
}

const { quote, author } = Astro.props;
---

<div class="bg-white rounded-2xl shadow-sm p-6 sm:p-8 flex flex-col">
  <svg class="w-8 h-8 text-accent/40 mb-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10H0z"/>
  </svg>
  <blockquote class="text-text leading-relaxed flex-1 italic">
    {quote}
  </blockquote>
  <p class="mt-4 pt-4 border-t border-bg-alt text-sm font-semibold text-primary-dark">
    — {author}
  </p>
</div>
