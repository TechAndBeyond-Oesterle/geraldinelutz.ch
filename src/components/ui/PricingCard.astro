---
interface Props {
  image: string;
  name: string;
  sessions: string;
  duration: string;
  tagline: string;
  description: string;
  price: string;
  priceDetail: string;
  bookingUrl?: string;
  infoUrl?: string;
}

const {
  image,
  name,
  sessions,
  duration,
  tagline,
  description,
  price,
  priceDetail,
  bookingUrl = 'https://calendly.com/coaching-geraldinelutz/coaching-a-90-minuten',
  infoUrl,
} = Astro.props;
---

<div class="bg-white rounded-2xl shadow-sm hover:shadow-lg transition-shadow duration-300 overflow-hidden flex flex-col">
  <div class="aspect-[4/3] overflow-hidden">
    <img src={image} alt={name} class="w-full h-full object-cover" loading="lazy" />
  </div>
  <div class="p-6 flex flex-col flex-1">
    <h3 class="font-serif text-xl font-semibold text-primary-dark">{name}</h3>
    <p class="text-sm text-text-light mt-1">{sessions} &middot; {duration}</p>
    <p class="text-sm font-medium text-accent mt-3 italic">{tagline}</p>
    <p class="text-sm text-text-light mt-2 flex-1">{description}</p>
    <div class="mt-4 pt-4 border-t border-bg-alt">
      <p class="text-2xl font-bold text-primary-dark">{price}</p>
      <p class="text-xs text-text-light">{priceDetail}</p>
    </div>
    <a
      href={infoUrl || bookingUrl}
      target={infoUrl ? '_self' : '_blank'}
      rel={infoUrl ? undefined : 'noopener noreferrer'}
      class="mt-4 block w-full text-center px-4 py-2.5 bg-accent hover:bg-accent-dark text-primary-dark font-bold rounded-full transition-colors text-sm"
    >
      {infoUrl ? 'Mehr Infos' : 'Buchen'}
    </a>
  </div>
</div>
