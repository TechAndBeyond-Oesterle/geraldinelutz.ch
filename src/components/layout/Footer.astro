---
const year = new Date().getFullYear();
---

<footer class="bg-primary-dark text-white/90">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
      <!-- Kontakt -->
      <div>
        <h3 class="font-serif text-lg font-semibold text-white mb-4">Kontakt</h3>
        <address class="not-italic text-sm leading-relaxed space-y-1">
          <p>Géraldine Lutz</p>
          <p>Oberdorfstrasse 25</p>
          <p>3303 Jegenstorf, Schweiz</p>
          <p class="mt-3">
            <a href="mailto:coaching@geraldinelutz.ch" class="hover:text-accent-light transition-colors">
              coaching@geraldinelutz.ch
            </a>
          </p>
          <p>
            <a href="tel:+41799330089" class="hover:text-accent-light transition-colors">
              +41 79 933 00 89
            </a>
          </p>
        </address>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-serif text-lg font-semibold text-white mb-4">Navigation</h3>
        <ul class="text-sm space-y-2">
          <li><a href="/angebot" class="hover:text-accent-light transition-colors">Angebot</a></li>
          <li><a href="/arbeitsweise" class="hover:text-accent-light transition-colors">Arbeitsweise</a></li>
          <li><a href="/ueber-mich" class="hover:text-accent-light transition-colors">Über mich</a></li>
          <li><a href="/kontakt" class="hover:text-accent-light transition-colors">Kontakt</a></li>
        </ul>
      </div>

      <!-- Social & Legal -->
      <div>
        <h3 class="font-serif text-lg font-semibold text-white mb-4">Verbinden</h3>
        <div class="flex items-center gap-4 mb-6">
          <a
            href="https://www.linkedin.com/in/geraldine-lutz-coaching"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center w-10 h-10 rounded-full bg-white/10 hover:bg-accent/80 transition-colors"
            aria-label="LinkedIn"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a
            href="https://visionvibes.ch"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm hover:text-accent-light transition-colors"
          >
            <img src="/images/logos/visionvibes.png" alt="VisionVibes" class="h-8 w-8 rounded-full" />
            VisionVibes
          </a>
        </div>
        <ul class="text-sm space-y-2 text-white/70">
          <li><a href="/impressum" class="hover:text-accent-light transition-colors">Impressum</a></li>
          <li><a href="/datenschutzerklaerung" class="hover:text-accent-light transition-colors">Datenschutzerklärung</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-white/20 text-center text-sm text-white/50">
      &copy; {year} géraldine lutz coaching. Alle Rechte vorbehalten.
    </div>
  </div>
</footer>
