---
import ContentLayout from '../../layouts/ContentLayout.astro';
import TestimonialCard from '../../components/ui/TestimonialCard.astro';

const sidebarLinks = [
  { label: 'Portrait', href: '/ueber-mich' },
  { label: 'Laufbahn', href: '/ueber-mich/laufbahn' },
  { label: 'Mission', href: '/ueber-mich/mission' },
  { label: 'Haltung', href: '/ueber-mich/haltung' },
  { label: 'Feedback', href: '/ueber-mich/feedback' },
];
---

<ContentLayout
  title="Feedback"
  description="Was andere über mein Coaching sagen: Ehrliche Feedbacks meiner Klient*innen."
  sidebarTitle="Über mich"
  sidebarLinks={sidebarLinks}
  breadcrumbs={[
    { label: 'Über mich', href: '/ueber-mich' },
    { label: 'Feedback' },
  ]}
>
  <p>Andere über mich als Coach...</p>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
    <TestimonialCard
      author="S.M."
      quote="Das Coaching mit Dir ist bereichernd und hilfreich – vielen herzlichen Dank für Deine Unterstützung! Deine entspannte Art und unkomplizierte Herangehensweise hat mich total abgeholt. Die Varietät Deiner Tools und deren gekonnte Einsetzung zum richtigen Zeitpunkt, wie auch die entsprechende Visualisierung unserer Sitzungsergebnisse hat für mich Klarheit gebracht und Verständnis geschaffen. Deine Ehrlichkeit und Offenheit schätze ich sehr. Im Coachingprozess wusste ich stets woran ich bin, wie es weitergeht und mit welchem Ziel wir uns treffen. So konnte ich jedes Mal mit einem guten Gefühl meine Ziele erreicht zu haben, entspannt nach Hause gehen. Ich freue mich auf das nächste Mal!"
    />
    <TestimonialCard
      author="M.K."
      quote="Du bist ein wunderbarer Coach! Mit deiner humorvollen, aufgestellten und einfühlsamen Art holst du mich immer wieder genau am richtigen Ort ab. Dadurch gelange ich sehr rasch zu meinen Erkenntnissen, die mich weiterbringen. Ich kann ein Coaching bei dir wärmstens empfehlen und danke dir ganz herzlich für die wertvollen Begleitungen."
    />
    <TestimonialCard
      author="T.L."
      quote="Das Coaching bei Géraldine hat mich definitiv weitergebracht. Obwohl ich mehrere Male unkonzentriert von ihrer ursprünglichen Fragestellung abgewichen bin, hat sie mir aufmerksam zugehört und mir danach unbeirrt immer wieder die richtigen Fragen gestellt, um mich zurück auf die Ziellinie zu bringen. Sie hat mich animiert, weiter zu denken, als ich es ohne Ihre Begleitung getan hätte und hat es geschafft, das ich wieder Lust dazu bekommen habe, mich mit meiner Zielsetzung auseinanderzusetzen. Ich fühlte mich im ganzen Setting verstandenen, ernst genommen und gut aufgehoben."
    />
  </div>
</ContentLayout>
